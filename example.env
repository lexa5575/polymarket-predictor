# Required
OPENAI_API_KEY="***"
XAI_API_KEY="***"
EXA_API_KEY="***"

# Optional
# ANTHROPIC_API_KEY="***"        # Phase 2
# XAI_MODEL_ID=grok-4-1-fast-non-reasoning    # Override default Grok model
COINGLASS_API_KEY="***"          # Optional — graceful degradation without it
# RUNTIME_ENV=dev
# TRACING_ENABLED=false          # Set to true when OpenTelemetry is installed

# Server port (default 8000, server uses 8001)
# API_PORT=8001

# Database (defaults work out of the box)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
